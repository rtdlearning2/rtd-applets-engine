      "applet": {
        "heading": "Reflection in the x-axis",
        "progressLabel": "Exploration 2",
        "graphLabels": {
          "original": "y = f(x)",
          "transformed": "y = g(x)"
        },
        "steps": [
          {
            "id": "q1",
            "type": "graph-plot",
            "questionLabel": "Question 1 (of 3)",
            "instructions": "Sketch the mirror image graph, <strong>y = g(x)</strong>, by clicking where the 5 connection points should be, and using the above controls.",
            "successMessage": "CORRECT - Your graph is bang on!",
            "explanation": "<p>Notice how the y-coordinate of all points on the transformed graph g(x) are the <i>negative</i> of the y-coordinate on the f(x).</p><p>This is a <b>vertical reflection</b> about the x-axis.</p>",
            "nextLabel": "Continue to Part 2 \u2192"
          },
          {
            "id": "q2",
            "type": "drag-drop-mapping",
            "questionLabel": "Question 2",
            "instructions": "Drag &amp; Drop the boxes below to state the <b>mapping rule</b> from f(x) to g(x).",
            "slots": [
              {
                "id": "x",
                "label": "NEW X"
              },
              {
                "id": "y",
                "label": "NEW Y"
              }
            ],
            "tokenBanks": [
              {
                "label": "X-values",
                "group": "x",
                "tokens": [
                  {
                    "value": "x",
                    "group": "x"
                  },
                  {
                    "value": "\u2212x",
                    "group": "x"
                  }
                ]
              },
              {
                "label": "Y-values",
                "group": "y",
                "tokens": [
                  {
                    "value": "y",
                    "group": "y"
                  },
                  {
                    "value": "\u2212y",
                    "group": "y"
                  }
                ]
              }
            ],
            "correctAnswer": {
              "x": "x",
              "y": "\u2212y"
            },
            "hint": "Check how the y-values change.",
            "successText": "Notice how each y-coordinate is replaced by its opposite value.",
            "nextLabel": "Continue to Part 3 \u2192"
          },
          {
            "id": "q3",
            "type": "drag-drop-sentences",
            "questionLabel": "Question 3",
            "instructions": "<strong>Drag &amp; drop</strong> to complete each statement.",
            "sentences": [
              {
                "prefix": "The points on both graphs are",
                "slots": [
                  {
                    "id": "p1",
                    "group": "point"
                  },
                  {
                    "separator": "and"
                  },
                  {
                    "id": "p2",
                    "group": "point"
                  }
                ]
              },
              {
                "prefix": "They have the same",
                "slots": [
                  {
                    "id": "coordType",
                    "group": "coordType"
                  },
                  {
                    "separator": ", which is"
                  },
                  {
                    "id": "value",
                    "group": "value"
                  }
                ]
              }
            ],
            "tokenBanks": [
              {
                "label": "Points:",
                "group": "point",
                "source": "computed:invariant-points",
                "distractors": [
                  [
                    0,
                    -1
                  ],
                  [
                    0,
                    1
                  ]
                ]
              },
              {
                "label": "Type:",
                "group": "coordType",
                "tokens": [
                  {
                    "value": "x-coordinate",
                    "group": "coordType"
                  },
                  {
                    "value": "y-coordinate",
                    "group": "coordType"
                  }
                ]
              },
              {
                "label": "Value:",
                "group": "value",
                "tokens": [
                  {
                    "value": "0",
                    "group": "value"
                  },
                  {
                    "value": "\u22121",
                    "group": "value"
                  }
                ]
              }
            ],
            "correctAnswer": {
              "p1": "computed:invariant-point",
              "p2": "computed:invariant-point",
              "coordType": "y-coordinate",
              "value": "0"
            },
            "successText": "A reflection in the x-axis keeps x-values the same and multiplies y-values by \u22121. Points on the x-axis have y = 0, so they do not move under the reflection. Therefore, the shared points are the x-intercepts, and they have the same y-coordinate, which is 0.",
            "nextLabel": "Finish Exploration \u2192"
          }
        ]
      }
    }
  ]
