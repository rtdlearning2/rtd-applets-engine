{
  "schemaVersion": "1",
  "title": "Reflect Across the Y-Axis (Curve)",
  "pages": [
    {
      "type": "applet",
      "showProgress": false,
      "showTitle": false,
      "showFooter": false,
      "ui": {
        "layout": {
          "preset": "ppt1080p",
          "overflowPolicy": "scroll",
          "safePadding": "4px",
          "contentPadding": "4px"
        }
      },
      "grid": {
        "xmin": -9,
        "xmax": 9,
        "ymin": -5,
        "ymax": 5
      },
      "interaction": {
        "mode": "placePoints",
        "snapStep": 1,
        "hitRadiusPx": 20
      },
      "original": {
        "curve": {
          "fn": "sqrt(x) - 2",
          "domain": [
            0,
            9
          ]
        },
        "points": [
          [
            0,
            -2
          ],
          [
            1,
            -1
          ],
          [
            4,
            0
          ],
          [
            9,
            1
          ]
        ]
      },
      "transform": {
        "type": "reflect_y"
      },
      "activity": {
        "type": "transformations",
        "activityModule": "../activities/transformations.js",
        "config": {
          "tolerance": 0,
          "requireExactCount": true
        }
      },
      "feedback": {
        "showExpectedPointsOnFail": false
      },
      "applet": {
        "heading": "Horizontal Reflections",
        "progressLabel": "Exploration 4 of 8",
        "graphLabels": {
          "original": "y = f(x)",
          "transformed": "y = g(x)"
        },
        "steps": [
          {
            "id": "q1",
            "type": "graph-plot",
            "questionLabel": "Question 1 (of 3)",
            "instructions": "Sketch the mirror image of the graph, reflected in the <strong>y-axis</strong>. Be sure to indicate the placement of the 4 indicated points. Label the new graph <strong>y = g(x)</strong>.",
            "successMessage": "CORRECT - Your graph is bang on!",
            "explanation": "<p>Notice how the x-coordinate of all points on the transformed graph g(x) are the <i>negative</i> of the x-coordinate on f(x), while the y-coordinate stays the same.</p><p>This is a <b>horizontal reflection</b> about the y-axis.</p>",
            "nextLabel": "Continue to Part 2 →"
          },
          {
            "id": "q2",
            "type": "drag-drop-mapping",
            "questionLabel": "Question 2",
            "instructions": "Drag &amp; Drop the boxes below to describe how the coordinates change.",
            "slots": [
              {
                "id": "x",
                "label": "NEW X"
              },
              {
                "id": "y",
                "label": "NEW Y"
              }
            ],
            "tokenBanks": [
              {
                "label": "X-values",
                "group": "x",
                "tokens": [
                  {
                    "value": "x",
                    "group": "x"
                  },
                  {
                    "value": "−x",
                    "group": "x"
                  }
                ]
              },
              {
                "label": "Y-values",
                "group": "y",
                "tokens": [
                  {
                    "value": "y",
                    "group": "y"
                  },
                  {
                    "value": "−y",
                    "group": "y"
                  }
                ]
              }
            ],
            "correctAnswer": {
              "x": "−x",
              "y": "y"
            },
            "hint": "Check how the x-values change.",
            "successText": "Each x-coordinate is replaced by its opposite, while y stays the same.",
            "nextLabel": "Continue to Part 3 →"
          },
          {
            "id": "q3",
            "type": "drag-drop-sentences",
            "questionLabel": "Question 3",
            "instructions": "State the equation, in terms of x, of <strong>y = g(x)</strong>.",
            "sentences": [
              {
                "prefix": "y = g(x) =",
                "slots": [
                  {
                    "id": "equation",
                    "group": "equation"
                  }
                ],
                "suffix": ""
              }
            ],
            "tokenBanks": [
              {
                "label": "Choose the equation:",
                "group": "equation",
                "tokens": [
                  {
                    "value": "sqrt_x_m2",
                    "group": "equation",
                    "html": "&#x221A;x − 2"
                  },
                  {
                    "value": "neg_sqrt_x_m2",
                    "group": "equation",
                    "html": "−&#x221A;x − 2"
                  },
                  {
                    "value": "sqrt_negx_m2",
                    "group": "equation",
                    "html": "&#x221A;(−x) − 2"
                  },
                  {
                    "value": "sqrt_x_p2",
                    "group": "equation",
                    "html": "&#x221A;x + 2"
                  }
                ]
              }
            ],
            "correctAnswer": {
              "equation": "sqrt_negx_m2"
            },
            "successText": "Replacing x with −x reflects the graph in the y-axis.",
            "nextLabel": "Finish Exploration →"
          }
        ]
      }
    }
  ]
}